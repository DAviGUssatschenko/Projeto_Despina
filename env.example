# ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores.
# NUNCA faça commit do .env real — adicione ao .gitignore.
# ─────────────────────────────────────────────

# Credenciais Copernicus / Sentinel Hub
CDSE_CLIENT_ID= 'YOURS_CLIENT_ID'
CDSE_CLIENT_SECRET= 'YOURS_SECRET_ID'

# Caminho para o shapefile EMBRAPA (relativo à raiz do projeto ou absoluto)
# Padrão: data/embrapa/aptagr_bra.shp  (relativo ao config.py)
# EMBRAPA_SHAPEFILE=/caminho/customizado/aptagr_bra.shp

# Diretório de saída para imagens de índices espectrais
# Padrão: output_indices  (relativo à raiz do projeto)
# OUTPUT_INDICES_DIR=/caminho/customizado/output_indices
